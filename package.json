{
  "name": "agent",
  "version": "1.0.0",
  "type": "module",
  "description": "You need to connect to a Deliveroo server.",
  "main": "main.ts",
  "scripts": {
    "setup": "node scripts/setup.js && npm install",
    "postinstall": "node scripts/setup.js",
    "start": "node --experimental-strip-types main.ts",
    "start:bdi": "node --experimental-strip-types main.ts",
    "start:llm": "node --experimental-strip-types main.ts --use-llm",
    "dev": "node --watch --experimental-strip-types main.ts",
    "test": "node --experimental-strip-types tests/llm_tests.ts",
    "test:skip-live": "node --experimental-strip-types tests/llm_tests.ts --skip-live",
    "test:verbose": "node --experimental-strip-types tests/llm_tests.ts --verbose",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pietroDeAngeli/Deliveroo_Agent.git"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@unitn-asa/deliveroo-js-sdk": "^1.3.3",
    "@unitn-asa/pddl-client": "^1.7.5",
    "city-timezones": "^1.3.4",
    "dotenv": "^17.4.1",
    "mathjs": "^15.2.0",
    "openai": "^6.38.0"
  },
  "engines": {
    "node": "22.x"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  }
}
