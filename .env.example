HOST=<link of the server>
AGENT_TOKEN_BDI=<token for the BDI agent>
AGENT_TOKEN_LLM=<token for the LLM agent>
USE_PDDL=false
# Set USE_PDDL=true to use the online PDDL solver instead of BFS.
# Requires internet access to solver.planning.domains (or set PDDL_SOLVER to a custom URL).
# PDDL_SOLVER=https://solver.planning.domains/solve

DEBUG=false
# Set DEBUG=true to enable verbose BDI step logs (desires, intentions, stuck detection, etc.)
# LLM messages are always printed regardless of this setting.

USE_LLM=false
# Set USE_LLM=true to enable the LLM reasoning layer on top of the BDI loop.
# Required for the LLM agent in multi-agent mode. The following variables must also be set.

# The following variables are needed if you use the LLM agent. Otherwise you can ignore them.
LITELLM_BASE_URL=<link of the LLM API>
LITELLM_API_KEY=<API key of the LLM>
LOCAL_MODEL=<model name>
